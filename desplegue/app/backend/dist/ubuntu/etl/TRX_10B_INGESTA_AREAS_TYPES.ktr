<?xml version="1.0" encoding="UTF-8"?>
<transformation>
  <info>
    <name>TRX_10B_INGESTA_AREAS_TYPES</name>
    <description>Extrae datos de public.areas_types (suia_enlisy) y los carga en stg.suia_areas_types_bi (dw_reg_v1)</description>
    <extended_description>Origen: 172.16.0.179:5632/suia_enlisy - Esquema: public - Tabla: areas_types
Destino: localhost:5632/dw_reg_v1 - Esquema: stg - Tabla: suia_areas_types_bi
Estrategia: TRUNCATE + INSERT (carga completa diaria)
v1.0: catalogo de tipos de area (OT, DP, DZ, PC, EA, ZONALES)</extended_description>
    <trans_type>Normal</trans_type>
    <trans_status>0</trans_status>
    <directory>/</directory>
  </info>
  <notepads>
    <notepad>
      <note>TRANSFORMACION 10B: Ingesta Tipos de Area SUIA (public.areas_types)
Origen: suia_enlisy @ 172.16.0.179:5632
Destino: dw_reg_v1 @ localhost:5632 / stg.suia_areas_types_bi
Catalogo: 7 tipos institucionales (PC, EA, DP, OT, DZ, ZONALES)</note>
      <xloc>50</xloc>
      <yloc>20</yloc>
      <width>440</width>
      <heigth>70</heigth>
    </notepad>
  </notepads>
  <connection>
    <name>CONN_SUIA_ENLISY</name>
    <server>172.16.0.179</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>suia_enlisy</database>
    <port>5632</port>
    <username>postgres</username>
    <password>postgres</password>
    <servername/>
    <data_tablespace/>
    <index_tablespace/>
    <attributes>
      <attribute><code>FORCE_IDENTIFIERS_TO_LOWERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>FORCE_IDENTIFIERS_TO_UPPERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>IS_CLUSTERED</code><attribute>N</attribute></attribute>
      <attribute><code>PORT_NUMBER</code><attribute>5632</attribute></attribute>
      <attribute><code>PRESERVE_RESERVED_WORD_CASE</code><attribute>Y</attribute></attribute>
      <attribute><code>QUOTE_ALL_FIELDS</code><attribute>Y</attribute></attribute>
      <attribute><code>SUPPORTS_BOOLEAN_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>SUPPORTS_TIMESTAMP_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>USE_POOLING</code><attribute>N</attribute></attribute>
    </attributes>
  </connection>
  <connection>
    <name>CONN_DWH_LOCAL</name>
    <server>localhost</server>
    <type>POSTGRESQL</type>
    <access>Native</access>
    <database>dw_reg_v1</database>
    <port>5632</port>
    <username>postgres</username>
    <password>postgres</password>
    <servername/>
    <data_tablespace/>
    <index_tablespace/>
    <attributes>
      <attribute><code>FORCE_IDENTIFIERS_TO_LOWERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>FORCE_IDENTIFIERS_TO_UPPERCASE</code><attribute>N</attribute></attribute>
      <attribute><code>IS_CLUSTERED</code><attribute>N</attribute></attribute>
      <attribute><code>PORT_NUMBER</code><attribute>5632</attribute></attribute>
      <attribute><code>PRESERVE_RESERVED_WORD_CASE</code><attribute>Y</attribute></attribute>
      <attribute><code>QUOTE_ALL_FIELDS</code><attribute>Y</attribute></attribute>
      <attribute><code>SUPPORTS_BOOLEAN_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>SUPPORTS_TIMESTAMP_DATA_TYPE</code><attribute>Y</attribute></attribute>
      <attribute><code>USE_POOLING</code><attribute>N</attribute></attribute>
    </attributes>
  </connection>
  <order>
    <hop>
      <from>Input SUIA Areas Types</from>
      <to>Output STG Areas Types</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <step>
    <name>Input SUIA Areas Types</name>
    <type>TableInput</type>
    <description>Lee catalogo de tipos de area desde public.areas_types</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type></partitioning>
    <connection>CONN_SUIA_ENLISY</connection>
    <sql>SELECT
    arty_id,
    arty_name,
    arty_abbreviation,
    arty_status
FROM public.areas_types</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <GUI>
      <xloc>150</xloc>
      <yloc>200</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
  <step>
    <name>Output STG Areas Types</name>
    <type>TableOutput</type>
    <description>Escribe en stg.suia_areas_types_bi</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><type>none</type></partitioning>
    <connection>CONN_DWH_LOCAL</connection>
    <schema>stg</schema>
    <table>suia_areas_types_bi</table>
    <commit>1000</commit>
    <truncate>Y</truncate>
    <ignore_errors>N</ignore_errors>
    <use_batch>Y</use_batch>
    <specify_fields>N</specify_fields>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_monthly>Y</partitioning_monthly>
    <tablename_in_field>N</tablename_in_field>
    <tablename_field/>
    <tablename_in_table>Y</tablename_in_table>
    <return_keys>N</return_keys>
    <return_field/>
    <GUI>
      <xloc>500</xloc>
      <yloc>200</yloc>
      <draw>Y</draw>
    </GUI>
  </step>
</transformation>
