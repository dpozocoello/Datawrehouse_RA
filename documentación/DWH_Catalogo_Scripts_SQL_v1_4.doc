                <th>Base de Datos</th>
                <th>Objeto / Schema</th>
            </tr>
        </thead>
        <tbody>
            <tr><td>SUIA Core</td><td>172.16.0.179</td><td>suia_enlisy</td><td>coa_mae / suia_iii</td></tr>
            <tr><td>JBPM DB</td><td>172.16.0.226</td><td>jbpmdb</td><td>online_payment</td></tr>
            <tr><td>JBPM Antiguo</td><td>172.16.0.226</td><td>jbpmdb_prod_old</td><td>public</td></tr>
        </tbody>
